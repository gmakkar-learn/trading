# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose default — change host/port if running postgres elsewhere
DATABASE_URL=postgresql+asyncpg://autotrader:autotrader@localhost:5432/autotrader

# ── Anthropic Claude API ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
# Required by SEC — format: "AppName contact@email.com"
SEC_EDGAR_USER_AGENT=auto-trader-01 your-email@example.com

# ── Alpaca (US paper trading) ──────────────────────────────────────────────────
# Get from https://app.alpaca.markets — paper trading account
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here

# ── Upstox (India sandbox trading) ────────────────────────────────────────────
# Get API key from https://developer.upstox.com — sandbox app
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_REDIRECT_URI=http://localhost:8080/callback
# Access token: run `uv run python scripts/upstox_auth.py` each trading day
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token: create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram chat ID: send /start to your bot, then check https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
